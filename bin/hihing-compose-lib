#!/usr/bin/env bash
set -euo pipefail

# Shared helpers for `docker-compose-*` wrappers.
# Copy this file into the same directory as the wrapper scripts
# (for example `/usr/local/bin`) so `source "${SCRIPT_DIR}/hihing-compose-lib"`
# keeps working after deployment.

detect_hihing_root() {
  if [ -n "${HIHING_ROOT:-}" ] && [ -f "${HIHING_ROOT}/docker-compose.yml" ]; then
    printf '%s\n' "${HIHING_ROOT}"
    return 0
  fi

  if [ -f "${PWD}/docker-compose.yml" ]; then
    printf '%s\n' "${PWD}"
    return 0
  fi

  echo "docker-compose.yml 이 있는 프로젝트 루트에서 실행하세요. 필요하면 HIHING_ROOT=/path/to/root 를 지정하세요." >&2
  return 1
}

HIHING_ROOT="$(detect_hihing_root)"
BASE_COMPOSE="${HIHING_ROOT}/docker-compose.yml"
DEV_COMPOSE="${HIHING_ROOT}/docker-compose.dev.yml"
PROD_COMPOSE="${HIHING_ROOT}/docker-compose.prod.yml"

usage_compose_mode() {
  cat <<'EOF' >&2
usage: docker-compose-up [dev|prod] [--log-level LEVEL] [platform|i-bff|o-bff|<compose-service> ...]

  서비스 미지정 시 docker-compose.yml + docker-compose.{dev|prod}.yml 병합 결과의 전체 서비스 대상
  축약어는 platform / i-bff / o-bff 만 인식 (그 외는 compose 서비스명 그대로)

  --log-level LEVEL   LOG_LEVEL 환경변수 주입 (미지정 시 셸의 LOG_LEVEL 사용)
                      예: warn / fatal,error,warn / fatal,error,warn,log
  env_file            .env.development|.env.production 없으면 .env 로 대체
EOF
}

usage_compose_target() {
  echo "usage: $1 [platform|i-bff|o-bff|<compose-service> ...]" >&2
  echo "  축약어: platform / i-bff / o-bff 만. 미지정 시 docker-compose.yml 전체 서비스" >&2
}

list_all_compose_services() {
  docker compose -f "${BASE_COMPOSE}" config --services
}

list_compose_services_for_files() {
  local -a compose_files=("$@")
  local -a cmd=(docker compose)
  local compose_file
  for compose_file in "${compose_files[@]}"; do
    cmd+=(-f "${compose_file}")
  done
  cmd+=(config --services)
  "${cmd[@]}"
}

build_compose_cmd() {
  local -a compose_files=("$@")
  local -a cmd=(docker compose)
  local compose_file
  for compose_file in "${compose_files[@]}"; do
    cmd+=(-f "${compose_file}")
  done
  printf '%s\n' "${cmd[@]}"
}

# `up --force-recreate` 실패 시 남는 `{hash}_{name}` 컨테이너를 제거한다.
prune_stale_recreate_containers() {
  local name
  while IFS= read -r name; do
    [ -n "${name}" ] || continue
    docker rm -f "${name}" >/dev/null 2>&1 || true
  done < <(docker ps -a --format '{{.Names}}' | rg '^[0-9a-f]{8,}_' || true)
}

compose_stop_services() {
  local -a services=("$@")
  if [ "${#services[@]}" -eq 0 ]; then
    docker compose -f "${BASE_COMPOSE}" stop
    return 0
  fi
  docker compose -f "${BASE_COMPOSE}" stop "${services[@]}"
}

compose_rm_services() {
  local -a services=("$@")
  prune_stale_recreate_containers
  if [ "${#services[@]}" -eq 0 ]; then
    docker compose -f "${BASE_COMPOSE}" rm -f >/dev/null 2>&1 || true
    return 0
  fi
  docker compose -f "${BASE_COMPOSE}" rm -f "${services[@]}" >/dev/null 2>&1 || true
}

compose_down_services() {
  local -a services=("$@")
  compose_stop_services "${services[@]}"
  compose_rm_services "${services[@]}"
}

detect_service_compose_mode() {
  local service="${1:-}"
  local container_id config_files

  container_id="$(docker compose -f "${BASE_COMPOSE}" ps -q "${service}" 2>/dev/null | head -n1 || true)"
  if [ -z "${container_id}" ] && docker inspect "${service}" >/dev/null 2>&1; then
    container_id="${service}"
  fi
  if [ -z "${container_id}" ]; then
    echo unknown
    return 0
  fi

  config_files="$(docker inspect "${container_id}" --format '{{index .Config.Labels "com.docker.compose.project.config_files"}}' 2>/dev/null || true)"
  case "${config_files}" in
    *docker-compose.prod.yml*) echo prod ;;
    *docker-compose.dev.yml*) echo dev ;;
    *) echo unknown ;;
  esac
}

compose_up_services() {
  local mode="${1:-}"
  shift || true
  local -a targets=("$@")
  local -a compose_files=()
  local -a compose_cmd=()
  local -a services=()
  local runtime_override=""

  mapfile -t compose_files < <(compose_files_for_mode "${mode}")
  runtime_override="${compose_files[-1]}"
  trap 'cleanup_runtime_compose_override "${runtime_override}"' RETURN
  ensure_node22_ffmpeg_image "${compose_files[@]}"

  mapfile -t compose_cmd < <(build_compose_cmd "${compose_files[@]}")
  prune_stale_recreate_containers

  if [ "${#targets[@]}" -eq 0 ]; then
    "${compose_cmd[@]}" up -d --force-recreate --remove-orphans
    return 0
  fi

  mapfile -t services < <(resolve_services "${targets[@]}")
  "${compose_cmd[@]}" up -d --force-recreate --remove-orphans "${services[@]}"
}

recreate_base_services() {
  local -a services=("$@")
  prune_stale_recreate_containers
  docker compose -f "${BASE_COMPOSE}" up -d --force-recreate --remove-orphans "${services[@]}"
}

recreate_services_with_mode_detection() {
  local -a targets=("$@")
  local -a services=()
  local -a dev_services=()
  local -a prod_services=()
  local -a base_services=()
  local service mode

  if [ "${#targets[@]}" -eq 0 ]; then
    mapfile -t services < <(list_all_compose_services)
  else
    mapfile -t services < <(resolve_services "${targets[@]}")
  fi

  if [ "${#services[@]}" -eq 0 ]; then
    echo "재생성할 서비스가 없습니다." >&2
    return 1
  fi

  for service in "${services[@]}"; do
    mode="$(detect_service_compose_mode "${service}")"
    case "${mode}" in
      dev) dev_services+=("${service}") ;;
      prod) prod_services+=("${service}") ;;
      *) base_services+=("${service}") ;;
    esac
  done

  if [ "${#dev_services[@]}" -gt 0 ]; then
    compose_up_services dev "${dev_services[@]}"
  fi
  if [ "${#prod_services[@]}" -gt 0 ]; then
    compose_up_services prod "${prod_services[@]}"
  fi
  if [ "${#base_services[@]}" -gt 0 ]; then
    echo "note: ${base_services[*]} — dev/prod 자동 감지 불가, base compose 로 재생성합니다. 최초 기동·모드 전환은 docker-compose-up dev|prod ... 를 사용하세요." >&2
    recreate_base_services "${base_services[@]}"
  fi
}

compose_files_for_mode() {
  local mode="${1:-}"
  local override=""
  local runtime_override=""
  local -a pre_runtime_files=()
  case "${mode}" in
    dev) override="${DEV_COMPOSE}" ;;
    prod) override="${PROD_COMPOSE}" ;;
    *)
      usage_compose_mode
      return 1
      ;;
  esac

  pre_runtime_files+=("${BASE_COMPOSE}")
  if [ -f "${override}" ]; then
    pre_runtime_files+=("${override}")
  fi

  printf '%s\n' "${pre_runtime_files[@]}"
  runtime_override="$(write_runtime_compose_override "${mode}" "${HIHING_COMPOSE_LOG_LEVEL:-}" "${pre_runtime_files[@]}")"
  printf '%s\n' "${runtime_override}"
}

cleanup_runtime_compose_override() {
  local runtime_override="${1:-}"
  if [ -n "${runtime_override}" ] && [ -f "${runtime_override}" ]; then
    rm -f "${runtime_override}"
  fi
}

write_runtime_compose_override() {
  local mode="${1:-}"
  local log_level="${2:-}"
  shift 2 || true
  python3 - "${HIHING_ROOT}" "${mode}" "${log_level}" "$@" <<'PY'
import json
import os
import subprocess
import sys
import tempfile

root, mode, log_level = sys.argv[1], sys.argv[2], sys.argv[3]
compose_files = sys.argv[4:]
suffix = "development" if mode == "dev" else "production"
node_env = "production" if mode == "prod" else "development"

service_dirs = {
    "hihing-i-bff-1": "hihing-i-services/bff",
    "hihing-i-bff-2": "hihing-i-services/bff",
    "hihing-o-bff-1": "hihing-o-services/bff",
    "hihing-o-bff-2": "hihing-o-services/bff",
    "hihing-platform-api-1": "hihing-platform-api",
    "hihing-platform-api-2": "hihing-platform-api",
    "tv_frontend": "hihing-i-services/tv_frontend",
    "hihing-i-admin": "hihing-i-services/hihing-i-admin",
    "square-web": "hihing-o-services/square-web",
    "square-admin": "hihing-o-services/square-admin",
    "hihing-chatbot": "hihing-o-services/hihing-chatbot",
    "market_backend": "market_backend",
    "market_admin": "market_admin",
}

def project_services() -> set[str]:
    if not compose_files:
        return set()
    cmd = ["docker", "compose"]
    for path in compose_files:
        cmd.extend(["-f", path])
    cmd.extend(["config", "--services"])
    try:
        out = subprocess.check_output(cmd, text=True, stderr=subprocess.DEVNULL)
    except subprocess.CalledProcessError:
        return set()
    return {line.strip() for line in out.splitlines() if line.strip()}

def resolve_env_files(rel_dir: str) -> list[str]:
    mode_env = os.path.join(root, rel_dir, f".env.{suffix}")
    dot_env = os.path.join(root, rel_dir, ".env")
    files: list[str] = []
    if os.path.isfile(mode_env):
        if os.path.isfile(dot_env):
            files.append(f"./{rel_dir}/.env")
        files.append(f"./{rel_dir}/.env.{suffix}")
    elif os.path.isfile(dot_env):
        files.append(f"./{rel_dir}/.env")
    return files

configured = project_services()
if not configured:
    fd, path = tempfile.mkstemp(prefix="hihing-compose-runtime.", suffix=".yml")
    os.close(fd)
    with open(path, "w", encoding="utf-8") as handle:
        handle.write("services: {}\n")
    print(path)
    raise SystemExit(0)

lines = ["services:"]
has_overrides = False
for service in sorted(configured):
    rel_dir = service_dirs.get(service)
    if not rel_dir:
        continue

    has_overrides = True
    lines.append(f"  {service}:")
    env_files = resolve_env_files(rel_dir)
    if env_files:
        lines.append("    env_file:")
        for path in env_files:
            lines.append(f"      - {path}")

    environment: dict[str, str] = {"NODE_ENV": node_env}
    if log_level:
        environment["LOG_LEVEL"] = log_level

    lines.append("    environment:")
    for key, value in environment.items():
        lines.append(f"      {key}: {json.dumps(value)}")

fd, path = tempfile.mkstemp(prefix="hihing-compose-runtime.", suffix=".yml")
os.close(fd)
with open(path, "w", encoding="utf-8") as handle:
    if has_overrides:
        handle.write("\n".join(lines) + "\n")
    else:
        handle.write("services: {}\n")
print(path)
PY
}

append_service_group() {
  local target="$1"
  case "${target}" in
    platform) printf '%s\n' hihing-platform-api-1 hihing-platform-api-2 ;;
    i-bff) printf '%s\n' hihing-i-bff-1 hihing-i-bff-2 ;;
    o-bff) printf '%s\n' hihing-o-bff-1 hihing-o-bff-2 ;;
    *) printf '%s\n' "${target}" ;;
  esac
}

resolve_services() {
  if [ "$#" -eq 0 ]; then
    return 1
  fi

  local target
  local service
  local -A seen=()
  local -a resolved=()

  for target in "$@"; do
    while IFS= read -r service; do
      [ -n "${service}" ] || continue
      if [ -z "${seen[${service}]+x}" ]; then
        resolved+=("${service}")
        seen["${service}"]=1
      fi
    done < <(append_service_group "${target}")
  done

  printf '%s\n' "${resolved[@]}"
}

resolve_services_if_any() {
  if [ "$#" -eq 0 ]; then
    return 0
  fi

  resolve_services "$@"
}

compose_service_exists() {
  local service_name="${1:-}"
  shift || true
  python3 - "$service_name" "$@" <<'PY'
import subprocess
import sys

service = sys.argv[1]
files = sys.argv[2:]
cmd = ["docker", "compose"]
for path in files:
    cmd.extend(["-f", path])
cmd.extend(["config", "--services"])

try:
    out = subprocess.check_output(cmd, text=True, stderr=subprocess.DEVNULL)
except subprocess.CalledProcessError:
    raise SystemExit(1)

services = {line.strip() for line in out.splitlines() if line.strip()}
raise SystemExit(0 if service in services else 1)
PY
}

ensure_node22_ffmpeg_image() {
  if [ "$#" -eq 0 ]; then
    return 0
  fi

  if ! compose_service_exists "node22-ffmpeg" "$@"; then
    return 0
  fi

  if docker image inspect node22-ffmpeg >/dev/null 2>&1; then
    return 0
  fi

  echo "node22-ffmpeg image missing; building once..." >&2
  (
    cd "${HIHING_ROOT}"
    local cmd=(docker compose)
    local compose_file
    for compose_file in "$@"; do
      cmd+=(-f "${compose_file}")
    done
    cmd+=(build node22-ffmpeg)
    "${cmd[@]}"
  )
}
