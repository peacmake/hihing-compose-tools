#!/usr/bin/env bash
set -euo pipefail

# Usage: docker-compose-down [platform|i-bff|o-bff|i-admin|tv|square|square-admin|nginx|<compose-service> ...]
# Example: docker-compose-down
# Example: docker-compose-down i-bff nginx
# Example: docker-compose-down compose-service-name

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/hihing-compose-lib"

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
  usage_compose_target "docker-compose-down"
  exit 0
fi

cd "${HIHING_ROOT}"
if [ "$#" -eq 0 ]; then
  docker compose -f "${BASE_COMPOSE}" stop
else
  mapfile -t services < <(resolve_services "$@")
  docker compose -f "${BASE_COMPOSE}" stop "${services[@]}"
fi
