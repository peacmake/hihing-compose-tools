#!/usr/bin/env bash
set -euo pipefail

# Usage: docker-compose-down [platform|i-bff|o-bff|<compose-service> ...]
# Example: docker-compose-down
# Example: docker-compose-down i-bff nginx
# Example: docker-compose-down compose-service-name
#
# stop 후 rm 까지 수행해 force-recreate 시 {hash}_{name} 충돌을 방지한다.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/hihing-compose-lib"

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
  usage_compose_target "docker-compose-down"
  exit 0
fi

cd "${COMPOSE_ROOT}"
if [ "$#" -eq 0 ]; then
  compose_down_services
else
  mapfile -t services < <(resolve_services "$@")
  compose_down_services "${services[@]}"
fi
