#!/usr/bin/env bash
set -euo pipefail

# Usage: docker-compose-restart [platform|i-bff|o-bff|i-admin|tv|square|square-admin|nginx|<compose-service> ...]
# Example: docker-compose-restart
# Example: docker-compose-restart platform
# Example: docker-compose-restart hihing-i-bff-1
#
# Uses `up --force-recreate` instead of `restart` so .env changes are applied.
# dev/prod is always auto-detected from running container compose labels.
# prod: reruns build+start command. dev: reloads env; code hot-reload is unchanged.
# LOG_LEVEL env (or docker-compose-up --log-level) applies on recreate via compose_up_services.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/hihing-compose-lib"

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
  usage_compose_target "docker-compose-restart"
  exit 0
fi

cd "${HIHING_ROOT}"
recreate_services_with_mode_detection "$@"
